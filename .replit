run = "cd apps/web && pnpm dev -- --port 3000"

[nix]
channel = "stable-24_05"

[languages.typescript]
languageServer = "typescript-language-server"

[deployment]
run = ["bash", "-lc", "cd apps/web && pnpm build && pnpm start -- --port 3000"]

[packager]
language = "nodejs"

[packager.build]
command = "pnpm install"

[hidden]
hidden = [
  ".next",
  "node_modules",
  "pnpm-lock.yaml",
  "**/.turbo"
]

[agent]
expertMode = true
